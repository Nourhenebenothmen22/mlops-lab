    "import mlflow\n",
    "from sklearn.datasets import load_diabetes\n",
    "\n",
    "mlflow.set_tracking_uri('http://mlflow-web:5000')\n",
    "model = mlflow.sklearn.load_model(\"models:/DiabetesModel@production\")\n",
    "db = load_diabetes()\n",
    "print(\"Prédictions:\", model.predict(db.data[:3]))"
   ]
